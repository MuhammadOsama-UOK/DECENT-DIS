rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. SITE SETTINGS
    match /site_settings/{settingsId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /site_settings/{settingsId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 2. LEADS / INQUIRIES
    // Public can create inquiries, only admin can read/manage them
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }

    // 3. SCRAP RATES
    // Publicly readable, admin managed
    match /scrap_rates/{rateId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 4. SELLING SCRAP / INVENTORY
    match /selling_scrap/{itemId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 5. TEST CONNECTION
    match /test/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // GLOBAL SAFETY NET - Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
